{
  "name": "template-discordbot",
  "description": "An esm nodejs template for discord bots using discord.js",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/template-discordbot"
  },
  "keywords": [
    "node",
    "esm",
    "discord",
    "discord.js",
    "bot",
    "template"
  ],
  "engines": {
    "node": "24",
    "pnpm": "10"
  },
  "imports": {
    "#/*": "./src/*.ts"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch ./src/main.ts | pino-pretty",
    "start": "node --env-file=.env ./src/main.ts",
    "lint": "pnpm lint-check --write",
    "lint-check": "biome check --diagnostic-level=warn --no-errors-on-unmatched",
    "typecheck": "tsc",
    "typecheck-staged": "tsc-files",
    "test": "vitest",
    "test-staged": "vitest related --bail=1 --reporter=github-actions",
    "test-ci": "vitest --bail=1 --reporter=github-actions",
    "register": "node --env-file=.env ./src/registration.ts",
    "unregister": "node --env-file=.env ./src/registration.ts --unregister",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@mkvlrn/config": "^3.1.12",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "lefthook": "^2.1.5",
    "pino-pretty": "^13.1.3",
    "tsc-files": "^1.1.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "vitest-mock-extended": "^4.0.0"
  },
  "dependencies": {
    "@mkvlrn/result": "^5.0.8",
    "@napi-rs/canvas": "^0.1.97",
    "discord.js": "^14.26.2",
    "envalid": "^8.1.1",
    "pino": "^10.3.1"
  }
}
