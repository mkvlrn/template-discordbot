{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchPackageNames": ["node", "pnpm"],
      "groupName": "engine-sync"
    },
    {
      "matchManagers": ["mise"],
      "groupName": "Toolchain (mise)",
      "excludePackageNames": ["node", "pnpm"]
    },
    {
      "matchManagers": ["npm"],
      "groupName": "Dependencies (pnpm)",
      "excludePackageNames": ["node", "pnpm"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["mise"],
      "matchPackageNames": ["biome"],
      "datasource": "github-releases",
      "packageName": "biomejs/biome"
    },
    {
      "matchManagers": ["mise"],
      "matchPackageNames": ["infisical"],
      "datasource": "github-releases",
      "packageName": "Infisical/cli",
      "extractVersion": "^v?(?<version>.*)$"
    },
    {
      "matchManagers": ["mise"],
      "matchPackageNames": ["cocogitto"],
      "datasource": "github-releases",
      "packageName": "cocogitto/cocogitto"
    }
  ],
  "rangeStrategy": "bump",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0
}
