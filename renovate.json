{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "mise": {
    "enabled": false
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.?mise\\.toml$"],
      "matchStrings": [
        "(?<depName>node|pnpm|biome|cocogitto|infisical)\\s*=\\s*\"(?<currentValue>.*?)\""
      ],
      "groupName": "Toolchain (mise)",
      "datasourceTemplate": "{{#if (or (eq depName 'node') (eq depName 'pnpm'))}}npm{{else}}github-releases{{/if}}",
      "packageNameTemplate": "{{#if (eq depName 'biome')}}biomejs/biome{{else}}{{#if (eq depName 'cocogitto')}}cocogitto/cocogitto{{else}}{{#if (eq depName 'infisical')}}Infisical/cli{{else}}{{{depName}}}{{/if}}{{/if}}{{/if}}"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["node", "pnpm"],
      "groupName": "engine-sync"
    },
    {
      "matchManagers": ["npm"],
      "groupName": "Dependencies (pnpm)",
      "excludePackageNames": ["node", "pnpm"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    }
  ],
  "rangeStrategy": "bump",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0
}
