{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.?mise\\.toml$"],
      "matchStrings": [
        "biome\\s*=\\s*\"(?<currentValue>.*?)\"",
        "cocogitto\\s*=\\s*\"(?<currentValue>.*?)\"",
        "infisical\\s*=\\s*\"(?<currentValue>.*?)\""
      ],
      "depNameTemplate": "{{{arg0}}}",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "{{#if (eq arg0 'biome')}}biomejs/biome{{else}}{{#if (eq arg0 'cocogitto')}}cocogitto/cocogitto{{else}}Infisical/cli{{/if}}{{/if}}"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["node", "pnpm"],
      "groupName": "engine-sync"
    },
    {
      "matchManagers": ["mise"],
      "groupName": "Toolchain (mise)",
      "excludePackageNames": ["node", "pnpm", "biome", "infisical", "cocogitto"]
    },
    {
      "matchPackageNames": ["biome", "cocogitto", "infisical"],
      "enabled": false,
      "matchManagers": ["mise"]
    },
    {
      "matchManagers": ["npm"],
      "groupName": "Dependencies (pnpm)",
      "excludePackageNames": ["node", "pnpm"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    }
  ],
  "rangeStrategy": "bump",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0
}
