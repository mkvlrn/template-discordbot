{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "mise": {
    "ignorePackageNames": ["biome", "cocogitto", "infisical"]
  },
  "packageRules": [
    {
      "matchPackageNames": ["node", "pnpm"],
      "groupName": "engine-sync"
    },
    {
      "matchManagers": ["mise"],
      "groupName": "Toolchain (mise)",
      "excludePackageNames": ["node", "pnpm"]
    },
    {
      "matchManagers": ["npm"],
      "groupName": "Dependencies (pnpm)",
      "excludePackageNames": ["node", "pnpm"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.?mise\\.toml$"],
      "matchStrings": ["(?<depName>biome|cocogitto|infisical)\\s*=\\s*\"(?<currentValue>.*?)\""],
      "groupName": "Toolchain (mise)",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "{{#if (eq depName 'biome')}}biomejs/biome{{else}}{{#if (eq depName 'cocogitto')}}cocogitto/cocogitto{{else}}Infisical/cli{{/if}}{{/if}}"
    }
  ],
  "rangeStrategy": "bump",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0
}
