{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchPackageNames": ["node", "pnpm"],
      "groupName": "engine-sync"
    },
    {
      "matchManagers": ["mise"],
      "groupName": "Toolchain (mise)",
      "excludePackageNames": ["node", "pnpm", "biome", "infisical", "cocogitto"]
    },
    {
      "matchManagers": ["npm"],
      "groupName": "Dependencies (pnpm)",
      "excludePackageNames": ["node", "pnpm"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.?mise\\.toml$"],
      "matchStrings": [
        "biome\\s*=\\s*\"(?<currentValue>.*?)\"",
        "cocogitto\\s*=\\s*\"(?<currentValue>.*?)\"",
        "infisical\\s*=\\s*\"(?<currentValue>.*?)\""
      ],
      "groupName": "Toolchain (mise)",
      "datasourceTemplate": "github-releases"
    }
  ],
  "rangeStrategy": "bump",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0
}
